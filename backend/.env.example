# ── Market ──────────────────────────────────────────────
MARKET_DEFAULT_SYMBOL=AAPL
MARKET_DEFAULT_INTERVAL=1d
MARKET_DEFAULT_PERIOD=6mo
MARKET_SYMBOLS=["AAPL","MSFT","TSLA","SPY","NVDA","AMZN"]

# ── Indicators ─────────────────────────────────────────
# Indicators are configured in backend/app/indicators.yaml
# (enable/disable each group and tune their parameters there)

# ── LLM ───────────────────────────────────────────────
# Provider: "openai_compat" or "llamacpp"
LLM_PROVIDER=openai_compat

# For Ollama (OpenAI-compatible mode):
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:14b
LLM_API_KEY=no-key

# For llama.cpp server:
# LLM_PROVIDER=llamacpp
# LLM_BASE_URL=http://localhost:8080

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=120

# ── App ────────────────────────────────────────────────
DEBUG=false
CORS_ORIGINS=["http://localhost:5173"]

# ── Scheduler ──────────────────────────────────────────
# Background analysis at intervals. Requires an LLM when INCLUDE_LLM=true.
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_MINUTES=60
# Leave empty to use MARKET_SYMBOLS, or set specific symbols:
# SCHEDULER_SYMBOLS=["AAPL","TSLA"]
SCHEDULER_INCLUDE_LLM=true
